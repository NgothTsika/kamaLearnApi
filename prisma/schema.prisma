generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Users & Authentication ----------
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  avatar       String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  role         UserRole @default(USER)

  xp         Int       @default(0)
  streak     Int       @default(0)
  lastActive DateTime?

  language       String?
  offlineEnabled Boolean @default(false)

  emailVerified Boolean @default(false)

  // Relations
  completedLessons    CompletedLesson[]
  quizSessions        QuizSession[]
  collectedCharacters CollectedCharacter[]
  userSubmissions     ContentSubmission[]
  contentReports      ContentReport[]      @relation("reporter")
  resolvedReports     ContentReport[]      @relation("resolver")
  offlineContent      OfflineContent[]
  collections         Collection[]
  userAchievements    UserAchievement[]
  pushTokens          PushToken[]
  gameMatchesPlayer1  GameMatch[]          @relation("player1")
  gameMatchesPlayer2  GameMatch[]          @relation("player2")
  gameMatchesWinner   GameMatch[]          @relation("winner")
  userProgress        UserProgress[]
  readingGoal         ReadingGoal?
  dailyActivities     DailyActivity[]
  lessonFeedback      LessonFeedback[]
  
  sessions          Session[]
  leaderboard       Leaderboard?
  notifications     Notification[]
  searchHistory     SearchHistory[]
  userAnalytics     UserAnalytics?
  comments          Comment[]
  auditLogs         AuditLog[]            @relation("adminLogs")
  followers         UserFollow[]          @relation("following")
  following         UserFollow[]          @relation("follower")
  bookmarks         Bookmark[]
  pollVotes         PollVote[]
  
  hearts            UserHearts?
  heartRecoveryEvents HeartRecoveryEvent[]
  
  userStreak        UserStreak?
  streakCheckIns    StreakCheckIn[]
  
  characterProgress UserCharacterProgress[]
  challengeProgress UserChallengeProgress[]

  // NEW: Chapter step responses and progress
  chapterPollResponses   ChapterPollResponse[]
  chapterChoiceResponses ChapterChoiceResponse[]
  chapterProgress        UserChapterProgress[]
  lessonProgress         UserLessonProgress[]
  chapterCompletions     ChapterCompletion[]
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

// ---------- Content Models ----------
model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  coverImage   String?
  slug         String   @unique
  description  String?
  icon         String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lessons            Lesson[]
  characterCategories CharacterCategory[]
  submissions        ContentSubmission[]
}

model CharacterCategory {
  id          String   @id @default(cuid())
  characterId String
  categoryId  String
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([characterId, categoryId])
  @@index([characterId])
  @@index([categoryId])
}

model CharacterLesson {
  id          String   @id @default(cuid())
  lessonId    String   @unique
  characterId String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson    Lesson    @relation("CharacterLessons", fields: [lessonId], references: [id], onDelete: Cascade)
  character Character @relation("LessonsByCharacter", fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([lessonId, characterId])
  @@index([characterId])
  @@index([lessonId])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  subtitle    String   @default("")
  coverImage  String?
  slug        String   @unique
  description String?
  hook        String?
  xpReward    Int      @default(10)
  isPremium   Boolean  @default(false)
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  deepDiveContent String?

  titleAudioUrl       String?
  hookAudioUrl        String?
  contentAudioUrl     String?
  deepDiveAudioUrl    String?

  prerequisites   LessonPrerequisite[] @relation("LessonPrerequisites_lesson")
  prerequisiteFor LessonPrerequisite[] @relation("LessonPrerequisites_prerequisite")
  followUps       LessonFollowUp[]     @relation("LessonFollowUps_lesson")
  followUpFor     LessonFollowUp[]     @relation("LessonFollowUps_followUp")

  chapters         Chapter[]
  quizzes          Quiz[]
  translations     LessonTranslation[]
  completedBy      CompletedLesson[]
  reports          ContentReport[]
  offlineContent   OfflineContent[]
  collectionItems  CollectionItem[]
  roadmapItems     RoadmapLevelLesson[]
  relatedCharacters CharacterLesson? @relation("CharacterLessons")
  userProgress     UserProgress[]
  lessonFeedback   LessonFeedback[]
  comments         Comment[]
  bookmarks        Bookmark[]

  // NEW: User lesson progress
  lessonProgress   UserLessonProgress[]
}

// ---------- Chapter with Intro & Interactive Steps ----------
model Chapter {
  id               String   @id @default(cuid())
  lessonId         String
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title            String
  coverImage       String?
  mediaType        String?
  mediaUrl         String?
  feedbackQuestion String?
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userProgress UserProgress[]

  // NEW: Chapter intro (text + audio, shown before steps, no progress)
  introText     String?
  introAudioUrl String?

  // NEW: Interactive steps inside this chapter
  steps ChapterStep[]
  quizzes Quiz[]

  // NEW: User chapter progress and completions
  chapterProgress    UserChapterProgress[]
  chapterCompletions ChapterCompletion[]
}

// ---------- Interactive Steps per Chapter ----------
model ChapterStep {
  id          String           @id @default(cuid())
  chapterId   String
  chapter     Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  order       Int
  type        ChapterStepType
  content     Json             // flexible: { body, title, options, correctOption, explanation, ... }
  mediaUrl    String?
  mediaType   String?          // "image", "video", "none"
  backgroundMusic Json?         // { url, volume }
  soundEffects    Json?         // [{ url, trigger, volume }]
  narration       Json?         // { url, defaultSpeed, defaultVolume }
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  pollResponses   ChapterPollResponse[]
  choiceResponses ChapterChoiceResponse[]

  @@unique([chapterId, order])
  @@index([chapterId])
}

enum ChapterStepType {
  TEXT
  TEXT_AUDIO
  IMAGE_FULL
  POLL
  CHOICE
  QUIZ_QUESTION
  RECAP
  CONTINUE_BUTTON
}

// User response to a poll step inside a chapter
model ChapterPollResponse {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepId      String
  step        ChapterStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  selectedOption Int
  createdAt   DateTime @default(now())

  @@unique([userId, stepId])
}

// User response to a choice step (analytics only, branching handled client‑side)
model ChapterChoiceResponse {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepId      String
  step        ChapterStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  selectedOption Int
  chosenStepId String?   // step ID the user navigated to (if branching)
  createdAt   DateTime @default(now())

  @@unique([userId, stepId])
}

// ---------- Progress Tracking (Chapter & Lesson) ----------
model UserChapterProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  currentStepIndex Int  @default(0)   // index into chapter's steps (ignores intro)
  completed   Boolean  @default(false)
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  @@unique([userId, chapterId])
  @@index([userId, completed])
}

model UserLessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  currentChapterIndex Int @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, lessonId])
}

model ChapterCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, chapterId])
}

// ---------- Legacy models (unchanged, for backward compatibility) ----------
model LessonPrerequisite {
  lessonId       String
  prerequisiteId String

  lesson       Lesson @relation("LessonPrerequisites_lesson", fields: [lessonId], references: [id], onDelete: Cascade)
  prerequisite Lesson @relation("LessonPrerequisites_prerequisite", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@id([lessonId, prerequisiteId])
}

model LessonFollowUp {
  lessonId   String
  followUpId String

  lesson   Lesson @relation("LessonFollowUps_lesson", fields: [lessonId], references: [id], onDelete: Cascade)
  followUp Lesson @relation("LessonFollowUps_followUp", fields: [followUpId], references: [id], onDelete: Cascade)

  @@id([lessonId, followUpId])
}

model LessonTranslation {
  id              String   @id @default(cuid())
  language        String
  title           String
  description     String?
  hook            String?
  deepDiveContent String?
  createdAt       DateTime @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, language])
}

// ---------- Quiz Models ----------
model Quiz {
  id               String   @id @default(cuid())
  lessonId         String
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  chapterId        String?
  chapter          Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  question         String
  type             String   @default("multiple_choice")
  options          Json
  optionImages     Json?
  correctOption    Int?
  explanation      String?
  order            Int      @default(0)
  heartLimit       Int      @default(4)
  timeLimitSeconds Int?
  difficulty       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  isActive Boolean  @default(true)
  tags     String[]

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  questionAudioUrl String?

  isPoll          Boolean  @default(false)
  pollDescription String?
  pollResults     Json?
  totalPollVotes  Int      @default(0)

  sessions        QuizSession[]
  gameRounds      GameRound[]
  attempts        QuizAttempt[]
  translations    QuizTranslation[]
  pollVotes       PollVote[]

  @@index([lessonId, chapterId, order])
}

model QuizTranslation {
  id              String   @id @default(cuid())
  quizId          String
  quiz            Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  language        String
  question        String
  options         Json
  explanation     String?
  pollDescription String?
  createdAt       DateTime @default(now())

  @@unique([quizId, language])
}

model QuizSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId          String
  quiz            Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  heartsRemaining Int
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  passed          Boolean?

  attempts QuizAttempt[]
}

model QuizAttempt {
  id             String      @id @default(cuid())
  sessionId      String
  session        QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId     String
  quiz           Quiz        @relation(fields: [questionId], references: [id])
  selectedOption Int
  isCorrect      Boolean
  heartLost      Boolean     @default(false)
  createdAt      DateTime    @default(now())
}

model PollVote {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  selectedOption Int
  votedAt        DateTime @default(now())

  @@unique([userId, quizId])
}

// ---------- Character Models ----------
model Character {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String
  imageUrl       String?
  story          String?
  xpThreshold    Int?
  rarityLevel    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entityType     String   @default("person")
  personType     String?
  placeType      String?
  eventType      String?
  traditionType  String?
  conceptType    String?
  metadata       Json?
  
  birthYear      Int?
  endYear        Int?
  country        String?
  achievements   Json?
  inventionImage String?

  categories CharacterCategory[]
  lessons    CharacterLesson[] @relation("LessonsByCharacter")
  unlockConditions CharacterUnlock[]
  userProgress     UserCharacterProgress[]

  translations CharacterTranslation[]
  collectedBy  CollectedCharacter[]
  collectionsContaining CharacterCollectionItem[] @relation("CharacterInCollections")
  
  @@index([entityType])
  @@index([personType])
  @@index([placeType])
  @@index([eventType])
  @@index([traditionType])
  @@index([conceptType])
  @@index([country])
}

model CharacterCollection {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  coverImage  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CharacterCollectionItem[]

  @@index([name])
  @@index([order])
}

model CharacterCollectionItem {
  id           String                @id @default(cuid())
  collectionId String
  collection   CharacterCollection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  characterId  String
  character    Character             @relation("CharacterInCollections", fields: [characterId], references: [id], onDelete: Cascade)
  order        Int                   @default(0)
  addedAt      DateTime              @default(now())

  @@unique([collectionId, characterId])
  @@index([collectionId])
  @@index([characterId])
}

model CharacterTranslation {
  id          String   @id @default(cuid())
  language    String
  name        String
  description String
  story       String?
  createdAt   DateTime @default(now())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, language])
}

model CompletedLesson {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  xpEarned    Int

  @@unique([userId, lessonId])
}

model CollectedCharacter {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  collectedAt DateTime  @default(now())

  characterCard CharacterCard?

  @@unique([userId, characterId])
}

model CharacterCard {
  id                   String             @id @default(cuid())
  collectedCharacterId String             @unique
  collectedCharacter   CollectedCharacter @relation(fields: [collectedCharacterId], references: [id], onDelete: Cascade)

  inventorName         String
  inventionName        String
  inventionDescription String?
  inventionImage       String?
  characterImage       String?

  year         String?
  country      String?
  achievements Json?
  impact       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Community & Other Features (unchanged) ----------
model ContentSubmission {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title          String
  description    String
  content        String?
  imageUrl       String?
  sources        String?
  status         SubmissionStatus @default(PENDING)
  moderatorNotes String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  reports ContentReport[]
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model OfflineContent {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  syncedAt DateTime @default(now())
  lastSync DateTime @updatedAt

  @@unique([userId, lessonId])
}

model ContentReport {
  id           String             @id @default(cuid())
  reporterId   String
  reporter     User               @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  lessonId     String?
  lesson       Lesson?            @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  submissionId String?
  submission   ContentSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  reason       String
  description  String?
  status       ReportStatus       @default(OPEN)
  createdAt    DateTime           @default(now())
  resolvedAt   DateTime?
  resolverId   String?
  resolver     User?              @relation("resolver", fields: [resolverId], references: [id], onDelete: SetNull)
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order        Int        @default(0)
  addedAt      DateTime   @default(now())

  @@unique([collectionId, lessonId])
}

model RoadmapLevel {
  id          String   @id @default(cuid())
  title       String
  description String?
  symbol      String?
  color       String?
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons RoadmapLevelLesson[]

  @@index([order])
  @@index([isPublished])
}

model RoadmapLevelLesson {
  id        String       @id @default(cuid())
  levelId   String
  level     RoadmapLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([levelId, lessonId])
  @@index([levelId, order])
  @@index([lessonId])
}

model Achievement {
  id             String   @id @default(cuid())
  name           String
  description    String
  icon           String?
  xpRequired     Int?
  streakRequired Int?
  createdAt      DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
}

model GameEvent {
  id              String   @id @default(cuid())
  eventName       String   @unique
  description     String?
  multiplier      Float
  durationHours   Int
  affectedSystem  String
  isActive        Boolean  @default(true)
  
  startsAt        DateTime @default(now())
  endsAt          DateTime
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([isActive])
  @@index([endsAt])
}

model LessonFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model Topic {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  coverImage  String?
  parentId    String?
  parent      Topic?   @relation("TopicSubcategories", fields: [parentId], references: [id], onDelete: SetNull)
  children    Topic[]  @relation("TopicSubcategories")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quizzes     Quiz[]
  gameMatches GameMatch[]
  lessons     Lesson[]
}

model GameMatch {
  id            String      @id @default(cuid())
  player1Id     String
  player1       User        @relation("player1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2Id     String?
  player2       User?       @relation("player2", fields: [player2Id], references: [id], onDelete: Cascade)
  winnerId      String?
  winner        User?       @relation("winner", fields: [winnerId], references: [id], onDelete: SetNull)
  heartsPlayer1 Int         @default(3)
  heartsPlayer2 Int         @default(3)
  status        MatchStatus @default(WAITING)
  startedAt     DateTime    @default(now())
  endedAt       DateTime?
  topicId       String?
  topic         Topic?      @relation(fields: [topicId], references: [id], onDelete: SetNull)
  quizPool      Json?

  playerCount Int @default(2)
  maxRounds   Int @default(5)

  rounds GameRound[]
}

enum MatchStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  CANCELLED
}

model GameRound {
  id               String    @id @default(cuid())
  matchId          String
  match            GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  questionId       String
  question         Quiz      @relation(fields: [questionId], references: [id])
  player1Answer    Int?
  player2Answer    Int?
  player1Correct   Boolean?
  player2Correct   Boolean?
  player1HeartLost Boolean?
  player2HeartLost Boolean?
  order            Int
  createdAt        DateTime  @default(now())
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  position  Int?
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model ReadingGoal {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyMinutes Int      @default(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DailyActivity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @default(now()) @db.Date
  minutesRead Int      @default(0)
  goalMet     Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model Leaderboard {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp           Int      @default(0)
  rank              Int?
  streakRecord      Int      @default(0)
  lessonsCompleted  Int      @default(0)
  charactersCollected Int    @default(0)
  gamesWon          Int      @default(0)
  updatedAt         DateTime @updatedAt

  @@index([totalXp])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  results   Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model UserAnalytics {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonsStarted       Int      @default(0)
  lessonsCompleted     Int      @default(0)
  averageCompletionTime Int?
  favoriteCategory     String?
  lastActiveAt         DateTime?
  updatedAt            DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content   String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("adminLogs", fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  entityType String
  entityId  String
  changes   Json?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, lessonId])
}

model UserHearts {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hearts          Int      @default(5)
  maxHearts       Int      @default(5)
  lastHeartLossAt DateTime?
  lastRecoveredAt DateTime?
  recoveryTimeMs  Int      @default(3600000)
  premiumUntil    DateTime?
  totalHeartLosses Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([lastHeartLossAt])
}

model HeartRecoveryEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  heartsRecovered Int
  fromHearts      Int
  toHearts        Int
  recoveryType    String
  createdAt DateTime @default(now())
  
  @@index([userId, createdAt])
}

model UserStreak {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastActivityAt  DateTime?
  streakStartedAt DateTime?
  streakFrozenUntil DateTime?
  freezesRemaining Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([lastActivityAt])
}

model StreakCheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  xpEarned  Int
  lessonCount Int
  quizCount Int
  createdAt DateTime @default(now())
  
  @@unique([userId, date])
  @@index([userId, date])
}

model CharacterUnlock {
  id          String   @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  unlockType  String
  lessonId    String?
  xpRequired  Int?
  xpCost      Int?
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  
  @@index([characterId])
  @@index([unlockType])
}

model UserCharacterProgress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId   String
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime?
  isCollected   Boolean  @default(false)
  favoriteLevel Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, characterId])
  @@index([userId, unlockedAt])
}

model DailyChallenge {
  id          String   @id @default(cuid())
  title       String
  description String?
  challengeType String
  targetCount Int
  xpReward    Int
  active      Boolean  @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userProgress UserChallengeProgress[]
  
  @@index([active, startDate])
}

model UserChallengeProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, challengeId])
  @@index([userId, completed])
}

model GameConfig {
  id String @id @default("gamification")
  heartsMaxHearts              Int    @default(5)
  heartsRecoveryTimeMs         Int    @default(3600000)
  heartsPremiumRecoveryTimeMs  Int    @default(1800000)
  streaksCheckInHours          Int    @default(24)
  streaksXpMultiplierFormula   String @default("1 + (currentStreak / 100)")
  streaksMilestones            Int[]  @default([7, 14, 30, 60, 100, 365])
  charactersUnlockXpThreshold  Int    @default(100)
  charactersPurchaseXpCost     Int    @default(50)
  gamificationEnabled          Boolean @default(true)
  gamificationEventMultiplier  Float   @default(1.0)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}
